# Port where the app is expected to run
PORT=8000

# Redis connection string for caching / queue operations
REDIS_URL=redis://redis:6379

# Path to the threat feed file (update if you store it elsewhere)
THREAT_FEED_PATH=data/firehol_level1.netset

# Path to server log file parsed by the app
SERVER_LOG_PATH=data/sample_nginx.log

# Path to locally trained model artifact
MODEL_PATH=models/threat_scorer.joblib

# Path to feature columns artifact used by the model
COLUMNS_PATH=models/feature_columns.joblib
